{
  "name": "kio-sl-legal-docs-rjs-app",
  "version": "0.2.0",
  "private": true,
  "dependencies": {
    "@testing-library/jest-dom": "^5.17.0",
    "@testing-library/react": "^13.4.0",
    "@testing-library/user-event": "^13.5.0",
    "aws-amplify": "^5.2.0",
    "bootstrap": "^5.3.2",
    "react": "^18.2.0",
    "react-bootstrap": "^2.9.2",
    "react-dom": "^18.2.0",
    "react-router-dom": "^7.9.5",
    "react-scripts": "5.0.1",
    "web-vitals": "^2.1.4"
  },
  "devDependencies": {
    "typescript": "4.9.5"
  },
  "scripts": {
    "start": "react-scripts start",
    "dev": "react-scripts start",
    "build": "react-scripts build",
    "test": "react-scripts test",
    "eject": "react-scripts eject",
    "clean-install": "node -e \"try{require('fs').rmSync('node_modules',{recursive:true,force:true})}catch(e){} try{require('fs').unlinkSync('package-lock.json')}catch(e){}\" && npm install",
    "migrate:assess": "amplify gen2-migration assess",
    "migrate:lock": "amplify gen2-migration lock",
    "migrate:lock:rollback": "amplify gen2-migration lock --rollback",
    "migrate:generate": "amplify gen2-migration generate"
  },
  "engines": {
    "node": ">=20"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "overrides": {
    "lodash": "4.17.21",
    "webpack": "5.94.0",
    "typescript": "4.9.5"
  }
}
